{
  "name": "timecal",
  "version": "1.3.0",
  "description": "A modern time tracking app for Windows built with Electron and Svelte.",
  "main": "./out/main/index.js",
  "author": "Rees@Apollo",
  "homepage": "https://github.com/rees-apollo/timecal",
  "repository": {
    "type": "git",
    "url": "https://github.com/rees-apollo/timecal.git"
  },
  "scripts": {
    "format": "prettier --plugin prettier-plugin-svelte --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "svelte-check": "svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "npm run typecheck:node && npm run svelte-check",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build:icons": "node scripts/build-icons.mjs",
    "build": "node scripts/build-icons.mjs && npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "rebuild:native": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir --win",
    "build:win": "npm run build && electron-builder --win",
    "package": "npm run build && electron-builder --dir --win",
    "make": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@schedule-x/calendar": "^4.5.0",
    "@schedule-x/drag-and-drop": "^3.7.3",
    "@schedule-x/events-service": "^4.5.0",
    "@schedule-x/resize": "^3.7.3",
    "@schedule-x/svelte": "^3.0.0",
    "@schedule-x/theme-shadcn": "^4.5.0",
    "@tailwindcss/vite": "^4.2.2",
    "electron-updater": "^6.8.3",
    "svelte-sonner": "^1.1.0",
    "tailwindcss": "^4.2.2",
    "temporal-polyfill": "^0.3.2",
    "winax": "^3.6.9"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@fontsource-variable/instrument-sans": "^5.2.8",
    "@fontsource-variable/nunito-sans": "^5.2.7",
    "@internationalized/date": "^3.12.1",
    "@lucide/svelte": "^1.8.0",
    "@sveltejs/vite-plugin-svelte": "6.1.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.19.17",
    "bits-ui": "^2.17.3",
    "clsx": "^2.1.1",
    "electron": "^35.3.2",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-svelte": "^3.17.0",
    "mode-watcher": "^1.1.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "shadcn-svelte": "^1.2.7",
    "sharp": "^0.34.2",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "to-ico": "^1.1.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.2"
  },
  "build": {
    "productName": "TimeCal",
    "win": {
      "target": "NSIS",
      "icon": "build/icon.ico"
    }
  }
}
